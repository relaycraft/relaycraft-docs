---
interface Props {
	title: string;
	description: string;
	link: string;
	icon: 'monitor' | 'rules' | 'ai' | 'scripting';
	text?: string;
}

const { title, description, link, icon, text = 'View Docs' } = Astro.props;

const icons = {
