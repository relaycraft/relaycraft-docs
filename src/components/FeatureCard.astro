	scripting: {
		color: '#EF4444', // Red 500
		bg: 'rgba(239, 68, 68, 0.1)',
		// Terminal/Laptop
		path: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />'
