const currentIcon = icons[icon];
---

<a href={link} class="feature-card no-underline group">
	<div class="icon-box">
		<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
			<g set:html={currentIcon.path} />
		</svg>
	</div>
	<div class="content">
		<h3 class="title">{title}</h3>
		<p class="description">{description}</p>
		<div class="link-text">
			{text} <span class="arrow">→</span>
		</div>
	</div>
</a>

<style define:vars={{ iconColor: currentIcon.color, iconBg: currentIcon.bg }}>
	.feature-card {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		background-color: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.75rem;
		text-decoration: none !important; /* Force override */
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		height: 100%;
		position: relative;
		overflow: hidden;
		z-index: 1; /* Default z-index */
	}

	.feature-card:hover {
		border-color: var(--iconColor);
		transform: translateY(-4px);
		box-shadow: 0 10px 30px -10px var(--iconBg);
		z-index: 10; /* Bring to front on hover */
	}

	.icon-box {
		width: 3rem;
		height: 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.75rem;
		background-color: var(--iconBg);
		color: var(--iconColor);
		margin-bottom: 1.25rem;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.feature-card:hover .icon-box {
		transform: scale(1.1) rotate(3deg);
	}

	.feature-card svg {
		width: 1.5rem;
		height: 1.5rem;
	}

	.content {
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--sl-color-white);
		margin-bottom: 0.5rem;
		line-height: 1.4;
	}

	.description {
		font-size: 0.9rem;
		color: var(--sl-color-gray-3);
		line-height: 1.6;
		margin-bottom: 1.5rem;
		flex: 1;
	}

	.link-text {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--iconColor);
		display: flex;
		align-items: center;
		gap: 0.375rem;
		margin-top: auto;
	}

	.arrow {
		transition: transform 0.3s ease;
	}

	.feature-card:hover .arrow {
		transform: translateX(4px);
	}
</style>