---
import Default from '@astrojs/starlight/components/Footer.astro';
const { lang } = Astro.props;
const isZh = lang === 'zh';

const textRights = isZh ? '保留所有权利。' : 'All rights reserved.';
const textMainSite = isZh ? '返回主站' : 'Main Site';
const textGitHub = isZh ? 'GitHub' : 'GitHub';
const textEmail = isZh ? '邮件联系' : 'Email';

// SVG Icons (inline, consistent with starlight's icon style)
---
<Default {...Astro.props} />
<footer class="relaycraft-footer">
	<div class="footer-inner">
		<div class="footer-links">
			<!-- Main Site -->
			<a href="https://relaycraft.dev" class="footer-icon-link" target="_blank" rel="noopener noreferrer" title={textMainSite}>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
					<path d="M219.31,108.68l-80-80a16,16,0,0,0-22.62,0l-80,80A15.87,15.87,0,0,0,32,120v96a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V160h32v56a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V120A15.87,15.87,0,0,0,219.31,108.68ZM208,208H160V152a8,8,0,0,0-8-8H104a8,8,0,0,0-8,8v56H48V120l80-80,80,80Z"/>
				</svg>
			</a>
			<!-- GitHub -->
			<a href="https://github.com/relaycraft/relaycraft" class="footer-icon-link" target="_blank" rel="noopener noreferrer" title={textGitHub}>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
					<path d="M208.31,75.68A59.78,59.78,0,0,0,202.93,28,8,8,0,0,0,196,24a59.75,59.75,0,0,0-48,24H124A59.75,59.75,0,0,0,76,24a8,8,0,0,0-6.93,4,59.78,59.78,0,0,0-5.38,47.68A58.14,58.14,0,0,0,56,104v8a56.06,56.06,0,0,0,48.44,55.47A39.8,39.8,0,0,0,96,192v8H72a24,24,0,0,1-24-24A40,40,0,0,0,8,136a8,8,0,0,0,0,16,24,24,0,0,1,24,24,40,40,0,0,0,40,40H96v16a8,8,0,0,0,16,0V192a24,24,0,0,1,48,0v40a8,8,0,0,0,16,0V192a39.8,39.8,0,0,0-8.44-24.53A56.06,56.06,0,0,0,216,112v-8A58.14,58.14,0,0,0,208.31,75.68ZM200,112a40,40,0,0,1-40,40H112a40,40,0,0,1-40-40v-8a41.74,41.74,0,0,1,6.9-22.48A8,8,0,0,0,80,58.52a44,44,0,0,1,.1-45,8,8,0,0,0,3.36-6.51A43.81,43.81,0,0,1,120,32h16a43.81,43.81,0,0,1,36.5,15,8,8,0,0,0,3.36,6.51,44,44,0,0,1,.1,45,8,8,0,0,0,1,6.52A41.72,41.72,0,0,1,200,104Z"/>
				</svg>
			</a>
			<!-- Email -->
			<a href="mailto:support@relaycraft.dev" class="footer-icon-link" title={textEmail}>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
					<path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-8,144H40V74.19l82.59,75.71a8,8,0,0,0,10.82,0L216,74.19V192Z"/>
				</svg>
			</a>
		</div>
		<p class="footer-copyright">© {new Date().getFullYear()} RelayCraft. {textRights}</p>
	</div>
</footer>

<style>
.relaycraft-footer {
    border-top: 1px solid var(--sl-color-border);
    margin-top: 4rem;
    padding: 2.5rem 0 2rem;
}

.footer-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
}

.footer-links {
	display: flex;
	justify-content: center;
	align-items: center;
	gap: 0.5rem;
}

.footer-icon-link {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 2.5rem;
	height: 2.5rem;
	border-radius: 8px;
	color: var(--sl-color-gray-3);
	text-decoration: none;
	transition: all 0.2s ease;
}

.footer-icon-link:hover {
	color: var(--sl-color-accent);
	background-color: var(--sl-color-gray-6);
	transform: translateY(-2px);
}

.footer-icon-link:active {
	transform: translateY(0);
}

.footer-copyright {
	font-size: 0.875rem;
	color: var(--sl-color-gray-4);
	margin: 0;
}

/* Dark mode adjustments */
:global([data-theme='dark']) .footer-icon-link:hover {
	background-color: var(--sl-color-gray-5);
}
</style>
