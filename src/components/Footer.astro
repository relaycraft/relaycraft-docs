---
import Default from '@astrojs/starlight/components/Footer.astro';
const { lang } = Astro.props;
const isZh = lang === 'zh';

const textRights = isZh ? '保留所有权利。' : 'All rights reserved.';
const textMainSite = isZh ? '返回主站' : 'Main Site';
---

<Default {...Astro.props} />

<footer class="relaycraft-footer">
	<div class="footer-inner">
		<div class="footer-links">
			<a href="https://relaycraft.dev">{textMainSite}</a>
			<span class="separator">•</span>
			<a href="https://github.com/relaycraft/relaycraft" target="_blank" rel="noopener noreferrer">GitHub</a>
			<span class="separator">•</span>
			<a href="mailto:support@relaycraft.dev">Email</a>
		</div>
		<p>© {new Date().getFullYear()} RelayCraft. {textRights}</p>
	</div>
</footer>

<style>
.relaycraft-footer {
    border-top: 1px solid var(--sl-color-border);
    margin-top: 4rem;
    padding: 2rem 0;
}

.footer-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    text-align: center;
    font-size: 0.875rem;
    color: var(--sl-color-gray-4);
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.footer-links {
	display: flex;
	justify-content: center;
	align-items: center;
	gap: 0.75rem;
}

.footer-links a {
	color: var(--sl-color-gray-3);
	text-decoration: none;
	transition: color 0.2s ease;
}

.footer-links a:hover {
	color: var(--sl-color-accent);
}

.separator {
	color: var(--sl-color-gray-5);
}
</style>
